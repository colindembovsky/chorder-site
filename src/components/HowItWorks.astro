---
const steps = [
  {
    n: '01',
    title: 'Import your charts',
    body: 'Drop in a stack of PDFs. Chorder reads chord and lyric structure on-device — text PDFs natively, scanned PDFs via OCR.',
  },
  {
    n: '02',
    title: 'Build a setlist',
    body: 'Add songs, set band and target keys, override capo per song, drop in performance notes. Reorder with a drag.',
  },
  {
    n: '03',
    title: 'Play live',
    body: 'Open Performance View. Swipe between songs, glance at Nashville numbers, and stay locked in to the moment.',
  },
];
---
<section id="how" class="py-20 sm:py-28 border-t border-border" style="background: var(--c-surface);">
  <div class="container-x">
    <div class="max-w-2xl">
      <p class="eyebrow">How it works</p>
      <h2 class="display text-3xl sm:text-4xl mt-2">Three steps from PDF to stage.</h2>
    </div>

    <ol class="mt-12 grid gap-6 md:grid-cols-3">
      {steps.map((s) => (
        <li class="card relative">
          <span class="display text-5xl" style="color: var(--c-primary); opacity: .35;">{s.n}</span>
          <h3 class="mt-3 font-display font-semibold text-xl">{s.title}</h3>
          <p class="mt-2 text-text/75 leading-relaxed">{s.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
