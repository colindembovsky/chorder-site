<section class="py-20 sm:py-24" style="background: #0f0f0f; color: #fff;">
  <div class="container-x grid md:grid-cols-[auto_1fr] gap-8 items-center">
    <div class="h-16 w-16 rounded-2xl flex items-center justify-center shrink-0"
         style="background: color-mix(in srgb, var(--c-accent) 18%, transparent); color: var(--c-accent);">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="1.8"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>
        <path d="m9 12 2 2 4-4"/>
      </svg>
    </div>
    <div>
      <p class="eyebrow" style="color: var(--c-accent);">Private by design</p>
      <h2 class="display text-2xl sm:text-3xl mt-2 text-white">
        Your charts, microphone audio, and library never leave your device.
      </h2>
      <p class="mt-3 text-white/75 max-w-3xl">
        Chorder is designed to work on your device. No account. No advertising. No analytics.
        No data uploads.
      </p>
    </div>
  </div>
</section>
