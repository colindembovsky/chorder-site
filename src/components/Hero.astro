---
import { APP_NAME, APP_TAGLINE, APP_SUBHEAD, PLAY_LIVE, PLAY_URL } from '../lib/constants';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section class="relative isolate overflow-hidden" style="background-color: #0a0a0a;">
  {/* Background: cover photo + dark vertical gradient (mirrors in-app splash) */}
  <div class="absolute inset-0 z-0">
    <img
      src={`${base}/images/cover.png`}
      alt=""
      class="w-full h-full object-cover"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0 hero-gradient"></div>
  </div>

  <div class="container-x relative z-10 pt-20 pb-28 sm:pt-28 sm:pb-36 lg:pt-36 lg:pb-44 text-center">
    <img
      src={`${base}/images/logo.png`}
      alt=""
      width="160"
      height="160"
      class="mx-auto h-28 w-28 sm:h-36 sm:w-36 rounded-2xl shadow-2xl object-cover"
      loading="eager"
      decoding="async"
    />

    <h1 class="display text-white mt-8 text-5xl sm:text-6xl lg:text-7xl">
      {APP_NAME}
    </h1>
    <p class="mt-4 text-lg sm:text-xl font-medium" style="color: #E0D9C8; opacity: 0.92;">
      {APP_TAGLINE}
    </p>
    <p class="mx-auto mt-6 max-w-2xl text-base sm:text-lg text-white/85 leading-relaxed">
      {APP_SUBHEAD}
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      {PLAY_LIVE ? (
        <a
          href={PLAY_URL}
          aria-label="Get Chorder on Google Play"
          class="inline-block transition-transform hover:-translate-y-0.5"
        >
          <img
            src={`${base}/images/google-play-badge.svg`}
            alt="Get it on Google Play"
            height="60"
            width="202"
            class="h-14 sm:h-[60px] w-auto"
          />
        </a>
      ) : (
        <span
          class="inline-flex items-center gap-2 rounded-full border border-white/30 px-5 py-3 text-sm font-semibold text-white/90 bg-white/5 backdrop-blur"
        >
          <span class="inline-block h-2 w-2 rounded-full bg-accent animate-pulse"></span>
          Coming soon to Google Play
        </span>
      )}
      <a href="#features" class="btn btn-ghost text-white border-white/30 hover:bg-white/10">
        See what it does
      </a>
    </div>
  </div>

  {/* Bottom fade into page bg */}
  <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-b from-transparent to-bg pointer-events-none"></div>
</section>
