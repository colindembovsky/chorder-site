---
import { APP_NAME, PUBLISHER, SUPPORT_EMAIL, COPYRIGHT_YEAR } from '../lib/constants';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteRoot = base ? `${base}/` : '/';
const sectionHref = (hash) => `${siteRoot}${hash}`;
---
<footer class="border-t border-border py-12 text-sm" style="background: var(--c-bg);">
  <div class="container-x grid gap-10 md:grid-cols-3">
    <div>
      <div class="flex items-center gap-2.5">
        <img src={`${base}/images/logo.png`} alt="" width="28" height="28" class="h-7 w-7 rounded-md object-cover" />
        <span class="font-display font-bold">{APP_NAME}</span>
      </div>
      <p class="mt-3 text-text/70 max-w-xs">
        Charts and setlists — your way. Built by {PUBLISHER}.
      </p>
    </div>

    <nav aria-label="Footer" class="flex flex-col gap-2 text-text/80">
      <p class="text-text/50 uppercase text-xs tracking-widest mb-1">Site</p>
      <a href={`${base}/`} class="hover:text-text">Home</a>
      <a href={sectionHref('#features')} class="hover:text-text">Features</a>
      <a href={sectionHref('#screenshots')} class="hover:text-text">Screenshots</a>
      <a href={sectionHref('#faq')} class="hover:text-text">FAQ</a>
      <a href={`${base}/privacy`} class="hover:text-text">Privacy policy</a>
    </nav>

    <div class="flex flex-col gap-2 text-text/80">
      <p class="text-text/50 uppercase text-xs tracking-widest mb-1">Contact</p>
      <a href={`mailto:${SUPPORT_EMAIL}`} class="hover:text-text break-all">{SUPPORT_EMAIL}</a>
    </div>
  </div>

  <div class="container-x mt-10 pt-6 border-t border-border text-xs text-text/55 flex flex-wrap gap-3 justify-between items-center">
    <p>© {COPYRIGHT_YEAR} {PUBLISHER}. All rights reserved.</p>
    <p>Google Play and the Google Play logo are trademarks of Google LLC.</p>
  </div>
</footer>
